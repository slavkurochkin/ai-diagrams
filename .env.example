# Copy to `.env` for local development (see README).

# Required for AI features (explain, design review, eval suggestions)
OPENAI_API_KEY=sk-...

# Production: leave unset or false on a public free demo so visitors cannot use your API key.
# Set to true only when you intentionally fund OpenAI usage (e.g. paid tier).
# ENABLE_SERVER_AI=true

# --- Optional: production / tuning ---

# Host port (Render etc. often set PORT automatically)
# PORT=3001

# Comma-separated browser origins allowed to call the API (cross-origin only).
# Dev: defaults to http://localhost:5173 — you usually don’t need this locally.
# Prod: set if the UI is on a different host than the API (e.g. CDN + API).
# CORS_ORIGINS=https://your-app.onrender.com

# Max JSON body size for /api (large flow context + documents)
# JSON_BODY_LIMIT=1mb

# Rate limit: max requests per IP per window (all /api routes share this bucket)
# API_RATE_LIMIT_MAX=60
# API_RATE_LIMIT_WINDOW_MS=900000
